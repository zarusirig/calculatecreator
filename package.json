{
  "name": "tiktok-creator-calculator",
  "version": "1.0.0",
  "description": "TikTok Creator Calculator Platform - Comprehensive monetization and analytics tools for TikTok creators",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate-sitemap && npm run optimize-images && next build",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "seo:normalize-internal-links": "node scripts/normalize-internal-links.js --write",
    "seo:check-internal-links": "node scripts/normalize-internal-links.js --check",
    "seo:check-redirect-chains": "node scripts/check-redirect-chains.js",
    "seo:check": "npm run seo:check-internal-links && npm run seo:check-redirect-chains",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "gen:image": "node scripts/gen-image.mjs",
    "optimize-images": "node scripts/optimize-images.js"
  },
  "dependencies": {
    "@fal-ai/client": "^1.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "axios": "^1.13.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.555.0",
    "next": "^14.2.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
