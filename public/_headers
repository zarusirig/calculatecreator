# Define caching headers for static hosting on platforms like Vercel, Netlify, or Cloudflare Pages
# These headers optimize browser and CDN caching for different asset types

# Long-term caching for images, fonts, and other static assets with content hashes
# These assets should be cached indefinitely because their URLs change when the content changes
/images/*
  Cache-Control: public, max-age=31536000, immutable

/static/*
  Cache-Control: public, max-age=31536000, immutable

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Font files should be cached for a very long time
/**/*.woff
  Cache-Control: public, max-age=31536000, immutable

/**/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/**/*.ttf
  Cache-Control: public, max-age=31536000, immutable

# CSS and JS files should be cached for a long time
/**/*.css
  Cache-Control: public, max-age=31536000, immutable

/**/*.js
  Cache-Control: public, max-age=31536000, immutable

# HTML pages should be cached for a shorter time to allow for content updates
# but still benefit from CDN caching
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# API responses should not be cached by default
/api/*
  Cache-Control: public, max-age=0, must-revalidate

# SEO pages should be revalidated frequently to ensure fresh content
/calculators/*
  Cache-Control: public, max-age=86400, must-revalidate

/guides/*
  Cache-Control: public, max-age=86400, must-revalidate

/news/*
  Cache-Control: public, max-age=3600, must-revalidate

# Sitemap and robots.txt should be cached briefly
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# Root page should be revalidated more frequently
/
  Cache-Control: public, max-age=3600, must-revalidate

# Security headers for all responses
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()