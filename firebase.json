{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/guides/how-to-get-brand-deals-complete{,/}",
        "destination": "/guides/how-to-get-brand-deals/",
        "type": 301
      },
      {
        "source": "/guides/how-to-join-creator-fund-complete{,/}",
        "destination": "/guides/how-to-join-creator-fund/",
        "type": 301
      },
      {
        "source": "/guides/tiktok-coin-converter-complete-guide{,/}",
        "destination": "/guides/tiktok-coins/",
        "type": 301
      },
      {
        "source": "/guides/how-creator-fund-works{,/}",
        "destination": "/guides/tiktok-creator-fund/",
        "type": 301
      },
      {
        "source": "/guides/increase-engagement-rate-tiktok{,/}",
        "destination": "/guides/how-to-increase-engagement/",
        "type": 301
      },
      {
        "source": "/guides/tiktok-live-earnings-expectations{,/}",
        "destination": "/guides/tiktok-live-earnings-guide/",
        "type": 301
      },
      {
        "source": "/guides/how-to-price-brand-deals{,/}",
        "destination": "/guides/brand-deals/",
        "type": 301
      },
      {
        "source": "/reference/creator-fund-eligible-countries{,/}",
        "destination": "/reference/creator-fund-countries/",
        "type": 301
      },
      {
        "source": "/reference/tiktok-shop-payment-schedule{,/}",
        "destination": "/reference/shop-payment-schedule/",
        "type": 301
      },
      {
        "source": "/advanced/creator-tax-deductions-guide{,/}",
        "destination": "/advanced/creator-tax-deductions/",
        "type": 301
      },
      {
        "source": "/resources/brand-deal-contract-template{,/}",
        "destination": "/resources/brand-deal-contract/",
        "type": 301
      },
      {
        "source": "/guides/creator-rewards-program{,/}",
        "destination": "/blog/how-tiktok-creator-rewards-work-2026/",
        "type": 301
      },
      {
        "source": "/blog/tiktok-vs-youtube-shorts-earnings-2026{,/}",
        "destination": "/comparisons/tiktok-vs-youtube-earnings/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|avif|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(woff|woff2|ttf|eot)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "_next/static/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "calculators/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
        ]
      },
      {
        "source": "guides/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
        ]
      },
      {
        "source": "news/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
        ]
      },
      {
        "source": "sitemap.xml",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "robots.txt",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "Content-Security-Policy", "value": "frame-src 'self' https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://www.google.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://pagead2.googlesyndication.com https://www.googletagmanager.com https://www.google-analytics.com" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
        ]
      }
    ]
  }
}
